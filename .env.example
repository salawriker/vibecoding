# Supabase 프로젝트 설정 (Supabase Dashboard > Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Drizzle DB 연결 문자열 (Supabase Dashboard > Project Settings > Database > Connection string)
# 커넥션 풀러(pooler) 주소 사용을 권장합니다.
DATABASE_URL=postgresql://postgres.xxxxxxxx:[YOUR-PASSWORD]@aws-0-region.pooler.supabase.com:6543/postgres

# Resend 이메일 알림 (https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# 발신 주소. 도메인 인증 전에는 onboarding@resend.dev 사용 가능(계정 소유 이메일로만 배달).
RESEND_FROM=onboarding@resend.dev
# 리드 알림을 받을 관리자 이메일
ADMIN_EMAIL=admin@example.com

# 어드민(/admin) Basic Auth. ADMIN_PASSWORD 미설정 시 /admin 접근 전면 차단.
ADMIN_USER=admin
ADMIN_PASSWORD=change-me

# PostHog 제품 분석 (PostHog Dashboard > Settings > Project > Project API Key)
# 키 미설정 시 계측은 자동으로 비활성화되고 앱은 그대로 동작합니다.
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 수집 엔드포인트(리전). US: https://us.i.posthog.com / EU: https://eu.i.posthog.com
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
